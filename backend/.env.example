# Oracle Autonomous Database (OCI)
ORACLE_USER=admin
ORACLE_PASSWORD=YourPassword123
ORACLE_DSN=your_db_name_high.adb.oraclecloud.com
ORACLE_WALLET_PASSWORD=YourWalletPassword123

# GROQ API
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: for local dev fallback to SQLite when Oracle unavailable
USE_SQLITE_FALLBACK=true
